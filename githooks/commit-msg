#!/bin/bash

FILE=$1
CONTENT=$(cat "$FILE")

if [ "$LINES" -lt 3 ]; then
  echo "❌ git commit -m 사용이 금지되어 있습니다."
  echo "👉 git commit 후 에디터에서 제목 + 본문을 작성하세요."
  exit 1
fi

TITLE=$(echo "$CONTENT" | head -n 1)
BODY=$(echo "$CONTENT" | tail -n +3)

PREFIX_REGEX="^\[(FEAT|BUGFIX|REFACTOR|CHORE|DOCUMENT|HOTFIX|ETC)\]"

# 1. 제목 prefix 검사
if [[ ! $TITLE =~ $PREFIX_REGEX ]]; then
  echo "❌ Invalid commit title format"
  echo "Example:"
  echo "[FEAT] User Login"
  exit 1
fi

# 2. 본문 필수 검사
if [[ -z "$(echo "$BODY" | tr -d '[:space:]')" ]]; then
  echo "❌ Commit body is required"
  echo "Write details below a blank line"
  exit 1
fi

# 3. prefix 추출
PREFIX=$(echo "$TITLE" | sed -E 's/^\[(.*)\].*/\1/')

# 4. 커밋 해시
SHORT_HASH=$(git rev-parse --short HEAD 2>/dev/null)
[ -z "$SHORT_HASH" ] && SHORT_HASH="init"

# 5. 제목 본문 분리
TITLE_BODY=$(echo "$TITLE" | sed -E 's/^\[[^]]+\][[:space:]]*//')

# 6. 새 메시지 구성
NEW_MSG="[$PREFIX/$SHORT_HASH] $TITLE_BODY

$BODY"

echo "$NEW_MSG" > "$FILE"

exit 0

